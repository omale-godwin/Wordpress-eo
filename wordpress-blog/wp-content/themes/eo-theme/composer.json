{
    "name": "electricoctopus/theme",
    "type": "wordpress-theme",
    "description": "Electric Octopus is a custom WordPress starter theme based on Electric Octopus. It's built for high-performance and custom design flexibility.",
    "keywords": [
        "WordPress",
        "Themes",
        "Electric Octopus"
    ],
    "homepage": "https://electricoctopus.agency",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Your Name or Agency Name",
            "homepage": "https://electricoctopus.agency"
        }
    ],
    "require": {
        "php": ">=7.4"
    },
    "require-dev": {
        "dealerdirect/phpcodesniffer-composer-installer": "^0.7.0",
        "wptrt/wpthemereview": "^0.2.1",
        "php-parallel-lint/php-parallel-lint": "^1.2.0",
        "wp-cli/i18n-command": "^2.2.5"
    },
    "scripts": {
        "lint:wpcs": "@php ./vendor/squizlabs/php_codesniffer/bin/phpcs",
        "lint:php": "@php ./vendor/bin/parallel-lint --exclude .git --exclude vendor .",
        "make-pot": "wp i18n make-pot . languages/electric-octopus.pot"
    },
    "support": {
        "issues": "https://github.com/YourGitHubUsername/electric-octopus-theme/issues",
        "source": "https://github.com/YourGitHubUsername/electric-octopus-theme"
    }
}
