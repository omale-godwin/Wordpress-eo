{"request":{"hurl":"https:\/\/blog.electricoctopus.agency\/wp-content\/themes\/eo-theme\/js\/ajax-post-detail.js","inline":"","enable_minification":true,"type":"js","handle":"ajax-post-detail","version":null},"log":{"url":"\/wp-content\/themes\/eo-theme\/js\/ajax-post-detail.js","success":true},"code":"jQuery(document).ready(function($){$('.recent-post-block a').on('click',function(e){e.preventDefault();var postURL=$(this).attr('href');$.ajax({url:postURL,type:'GET',success:function(response){var newContent=$(response).find('.main-body-container').html();$('.main-body-container').html(newContent);window.history.pushState(null,'',postURL)},error:function(){alert('Failed to load the post. Please try again.')}})})});\n","status":true}