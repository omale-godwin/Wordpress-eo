{"request":{"hurl":"https:\/\/blog.electricoctopus.agency\/wp-content\/themes\/eo-theme\/js\/dropdown-menu.js","inline":"","enable_minification":true,"type":"js","handle":"dropdown-menu","version":null},"log":{"url":"\/wp-content\/themes\/eo-theme\/js\/dropdown-menu.js","success":true},"code":"jQuery(document).ready(function($){$('.menu-item-has-children > a').on('click',function(e){var $submenu=$(this).siblings('.sub-menu');if($submenu.length>0){e.preventDefault();$submenu.stop(!0,!0).slideToggle(200);$('.sub-menu').not($submenu).slideUp(200)}});$(document).on('click',function(e){if(!$(e.target).closest('.header-menu').length){$('.sub-menu').slideUp(200)}})});\n","status":true}