{"request":{"hurl":"https:\/\/blog.electricoctopus.agency\/wp-content\/themes\/eo-theme\/js\/ajax-search-filter.js","inline":"","enable_minification":true,"type":"js","handle":"ajax-search-filter","version":null},"log":{"url":"\/wp-content\/themes\/eo-theme\/js\/ajax-search-filter.js","success":true},"code":"jQuery(document).ready(function($){let selectedTags=[];function fetchPosts(){const filters={action:\"filter_search_articles\",category_slug:$(\"#search-category-dropdown\").val(),industry_slug:$(\"#search-industry-dropdown\").val(),search:$(\"#search-input\").val().trim(),};if(!filters.category_slug&&!filters.industry_slug&&!filters.search){return}\n$.ajax({url:ajax_filter_params.ajax_url,type:\"POST\",data:filters,beforeSend:function(){$(\"#search-filtered-posts\").html(\"<p class='white'>Loading...<\/p>\")},success:function(response){$(\"#search-filtered-posts\").html(response);updateTags()},error:function(xhr,status,error){console.error(\"AJAX Error:\",status,error);$(\"#search-filtered-posts\").html(\"<p>An error occurred while fetching posts.<\/p>\")},})}\nfunction updateTags(){let visibleTags=new Set();$(\".custom-tag-link\").removeClass(\"enabled\").addClass(\"disabled-tag\");$(\"#search-filtered-posts .grid-item:visible\").each(function(){$(this).find(\".custom-tag-link\").each(function(){let tagID=$(this).data(\"tag-id\");visibleTags.add(tagID)})});$(\".articles-tags .custom-tag-link\").each(function(){let tagID=$(this).data(\"tag-id\");if(visibleTags.has(tagID)){$(this).removeClass(\"disabled-tag\").addClass(\"enabled\")}})}\n$(\"#search-category-dropdown, #search-industry-dropdown\").on(\"change\",fetchPosts);$(\"#search-input\").on(\"input\",fetchPosts);$(document).on(\"click\",\".custom-tag-link.enabled\",function(){const tagID=$(this).data(\"tag-id\");if(selectedTags.includes(tagID)){selectedTags=selectedTags.filter(id=>id!==tagID);$(this).removeClass(\"selected-tag\")}else{if(selectedTags.length<7){selectedTags.push(tagID);$(this).addClass(\"selected-tag\")}else{alert(\"You can only select up to 7 tags.\")}}\n$(\".grid-item .custom-tag-link\").each(function(){const tagLinkID=$(this).data(\"tag-id\");$(this).toggleClass(\"selected-tag\",selectedTags.includes(tagLinkID))});$(\".custom-tag-count\").toggleClass(\"highlighted-tag\",selectedTags.length>2)})});\n","status":true}