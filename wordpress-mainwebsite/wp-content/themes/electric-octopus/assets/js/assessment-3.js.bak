          subtitle: "Select all that apply to your business",
          groups: [
            {
              key: "budget",
              title: "Monthly Budget",
              options: [
                "$10,000 – $25,000",
                "$25,000 – $50,000",
                "$50,000 – $75,000",
                "$75,000 – $100,000",
                "$50,000+"
              ]
            },
            {
              key: "duration",
              title: "Estimated Project Duration",
              options: [
                "1–2 weeks",
                "2–4 weeks",
                "1–2 months",
                "2–6 months",
                "6 months +"
              ]
            }
          ]
        }
      ]
    },
    {
      id: 8,
      type: "language-flow",
      screens: [
        {
          type: "confirmation",
          title: "Confirmation",
          subTitle: "Data Privacy Audit",
          description:
            "In order to comply with privacy regulations in the European Union we’ll need you to provide consent before confirming you to our email list:",
          consents: [
            {
              key: "promo_emails",
              label:
                "",
              hint:
                ""
            }
          ],
          agreementText:
            "By submitting this form I agree to Electric Octopus",
          termsText: "Terms of Service",
          privacyText: "Privacy Policy"
        }
      ]
    }


  ];

  let currentStep = 0;
  let currentSubStep = 0;
  const answers = {};

  const stepContent = document.getElementById("step-content");
  const indicator = document.getElementById("step-indicator");
  const prevBtn = document.getElementById("prev-step");
  const nextBtn = document.getElementById("next-step");

  function renderStep() {

    const wrapper = document.querySelector(".part3-wrapper");
    const step = steps[currentStep];

    wrapper.classList.toggle("first-step", currentStep === 0);

    indicator.innerHTML = `${currentStep + 1} / <span class="total-steps">8</span>`;
    prevBtn.disabled = currentStep === 0;

    let html = "";

    if (step.label) {
      html += `<span class="part3-step-label">${step.label}</span>`;
    }
 /* ---------- NORMAL OPTIONS ---------- */
    if (step.type === "single" || step.type === "multi") {
      html += `<div class="options">`;
       if (step.title) {
          html += `<h2 class="options-heading mb-0">${step.title}</h2>`;
        }     
      step.options.forEach(opt => {
        const stored = answers[step.id];

        const active =
          step.type === "single"
            ? stored === opt
            : Array.isArray(stored) && stored.includes(opt);
        // 🔹 ONE heading
  
        html += `
          <button
            class="commonoption-cls option ${active ? "active" : ""}"
            data-step="${step.id}"
            data-key="root"
            data-type="${step.type}"
            data-value="${opt}"
          >
            ${opt}
          </button>
        `;
      });

      html += `<p class="language-hint mt-0">Select all that apply to your business</p>`;
      html += `</div>`;
    }

    if (step.type === "ads-flow") {

      const screen = step.screens[currentSubStep];

      html += `<h2>${screen.title}</h2>`;

      if (screen.subtitle) {
        html += `<p class="subtitle">${screen.subtitle}</p>`;
      }

      if (screen.type === "multi" && screen.iconOnly) {

        html += `<div class="icon-grid grid-2">`;

        screen.options.forEach(opt => {

          const active = (answers[step.id]?.[screen.key] || []).includes(opt.value);

          html += `
            <button
              class="indudtry-icon-card ${active ? "active" : ""}"
              data-step="${step.id}"
              data-key="${screen.key}"
              data-type="multi"
              data-value="${opt.value}"
            >
              <span class="indus-icon">
                <img src="${opt.icon}" alt="${opt.value}">
              </span>
              <span class="icon-label">${opt.value}</span>
            </button>
          `;
        });

        html += `</div>`;
      }

     
      /* ---------- GROUP MULTI (STEP 2) ---------- */
      if (screen.type === "group-multi") {

          screen.groups.forEach(group => {

            html += `
              <div class="service-group">
                <div class="service-heading">${group.heading}</div>
                <div class="service-options">
            `;

            const isOdd = group.options.length % 2 !== 0;

            group.options.forEach((opt, index) => {

              const active =
                (answers[step.id]?.[screen.key] || []).includes(opt);

              const isLastSingle =
                isOdd && index === group.options.length - 1;

              html += `
                <button
                  class="commonoption-cls option ${active ? "active" : ""} ${isLastSingle ? "full-width" : ""}"
                  data-step="${step.id}"
                  data-key="${screen.key}"
                  data-type="multi"
                  data-value="${opt}"
                >
                  ${opt}
                </button>
              `;
            });

            html += `
                </div>
              </div>
            `;
          });
        }
    }
/* ---------- STEP 3 : PROJECT DETAILS ---------- */
      if (step.type === "project-details") {

        const data = answers[step.id] || {};
        const titleVal = data.title || "";
        const descVal = data.description || "";

        const titleMax = step.screen.fields.title.max;
        const descMax = step.screen.fields.description.max;

        const titleExceeded = titleVal.length > titleMax;
        const descExceeded = descVal.length > descMax;

        html += `
            <div class="project-details-wrap">

              <h2 class="step-title">${step.screen.title}</h2>

              <!-- Project Title -->
              <label class="field-label">
                ${step.screen.fields.title.label}
                <span>(Max ${titleMax} letters)</span>
              </label>

              <textarea
                class="project-textarea title-textarea"
                rows="2"
                placeholder="${step.screen.fields.title.placeholder}"
                data-step="${step.id}"
                data-field="title"
              >${titleVal}</textarea>

              <div class="error-text title-error" style="display:none;">
                You have crossed the limit.
              </div>

              <!-- Project Description -->
              <label class="field-label">
                ${step.screen.fields.description.label}
                <span>(Max ${descMax} letters)</span>
              </label>

              <textarea
                class="project-textarea"
                rows="6"
                placeholder="${step.screen.fields.description.placeholder}"
                data-step="${step.id}"
                data-field="description"
              >${descVal}</textarea>

              <div class="error-text desc-error" style="display:none;">
                You have crossed the limit.
              </div>

            </div>
          `;
      }
    /* ---------- STEP 4 : LANGUAGE FLOW ---------- */
     if (step.type === "language-flow") {
      const screen = step.screens[currentSubStep];
      const stored = answers[step.id]?.languages;
      const isMulti = screen.select === "multi";

      const selected = isMulti
        ? (Array.isArray(stored) ? stored : [])
        : stored;


      if (screen.type === "language-grid") {
        html += `<span class="part3-step-label">KEY REQUIREMENTS</span>`;

        const groups = screen.groups || [
          {
            key: screen.key || "languages",
            title: screen.title,
            options: screen.options
          }
        ];

        groups.forEach(group => {
          const stored = answers[step.id]?.[group.key];
          const isMulti = screen.select === "multi";

          const selected = isMulti
            ? (Array.isArray(stored) ? stored : [])
            : stored;

          const total = group.options.length;
          const isOdd = total % 2 !== 0;

          html += `<h2>${group.title}</h2>`;
          html += `<div class="language-grid">`;

          group.options.forEach((option, index) => {
            const active = isMulti
              ? selected.includes(option)
              : selected === option;

            const isLastSingle = isOdd && index === total - 1;

            html += `
              <button
                class="language-btn ${active ? "active" : ""} ${isLastSingle ? "full-width" : ""}"
                data-step="${step.id}"
                data-key="${group.key}"
                data-type="${screen.select}"
                data-value="${option}">
                ${option}
              </button>
            `;
          });

          html += `</div>`;
        });

        html += `<p class="language-hint">${screen.subtitle}</p>`;
      }

      if (screen.type === "language-confirm") {
        html += `<div class="language-confirm-card">
          <h2>${screen.title}</h2>
          <ul class="selected-language-list">
            ${selected.length ? selected.map(lang => `<li>${lang}</li>`).join("") : `<li class="muted">No language selected</li>`}
          </ul>
          <h3 class="lang-subhead">${screen.subtitle}</h3>
          <p class="confirm-para">${screen.confirmPara}</p>
          <label class="checkbox-wrap">
            <input type="checkbox" data-step="${step.id}" data-key="confirm" ${answers[step.id]?.confirm ? "checked" : ""} />
            <span>${screen.checkboxText}</span>
          </label>
        </div>`;
      }
      if (screen.type === "confirmation") {
      const stored = answers[step.id] || {};

      html += `
        <span class="part3-step-label">KEY REQUIREMENTS</span>
        <h2>${screen.title}</h2>

        <h3 class="confirm-subtitle">${screen.subTitle}</h3>
        <p class="confirm-desc">${screen.description}</p>

        <div class="confirm-consents">
          ${screen.consents.map(item => `
            <label class="confirm-checkbox">
              <input
                type="checkbox"
                data-step="${step.id}"
                data-key="${item.key}"
                data-required="true"
                ${stored[item.key] ? "checked" : ""}
              />

              <span>
                <strong>I consent to receive promotional emails about your products and services
                  <br/>We’ll send you occasional emails about promotions, new products, and partnerships</strong>
                <small>I consent to allow my data to be used to personalize ads<br/>
                  For example we’ll use this to show more relevant ads and avoid showing you ads for products you’ve already purchased</small>
              </span>
            </label>
          `).join("")}
        </div>

        <div class="privacy-link">See Privacy Policy</div>

        <label class="confirm-checkbox agreement">
          <input
            type="checkbox"
            data-step="${step.id}"
            data-key="agreement"
            data-required="true"
            ${stored.agreement ? "checked" : ""}
          />

          <span>
            ${screen.agreementText}
            <a href="#">${screen.termsText}</a> and
            <a href="#">${screen.privacyText}</a>.
          </span>
        </label>

        <div class="recaptcha-box">
          <div class="recaptcha-mock">
            <input type="checkbox" disabled />
            <span>I’m not a robot</span>
            <img src="https://www.gstatic.com/recaptcha/api2/logo_48.png" />
          </div>
        </div>

        <button
          class="submit-btn ${stored.agreement ? "active" : "disabled"}"
          ${stored.agreement ? "" : "disabled"}
        >
          SUBMIT
        </button>
      `;
      }
    }

    stepContent.innerHTML = html;

    stepContent.querySelectorAll("button").forEach(btn => {

      btn.onclick = () => {

        // 🔒 prevent double handling for language buttons
        if (btn.classList.contains("language-btn")) return;

        const stepId = btn.dataset.step;
        const key = btn.dataset.key;
        const type = btn.dataset.type;
        const value = btn.dataset.value;

        if (key === "root") {
          if (type === "single") {
            answers[stepId] = value;
          } else {
            const list = Array.isArray(answers[stepId]) ? answers[stepId] : [];

            answers[stepId] = list.includes(value)
              ? list.filter(v => v !== value)
              : [...list, value];
          }
        } else {
          answers[stepId] = answers[stepId] || {};

          if (type === "single") {
            answers[stepId][key] = value;
          } else {
            answers[stepId][key] = answers[stepId][key] || [];

            answers[stepId][key].includes(value)
              ? answers[stepId][key] = answers[stepId][key].filter(v => v !== value)
              : answers[stepId][key].push(value);
          }
        }


        renderStep();
      };
    });

  }
/* =========================
   Textarea LISTENER (ADD HERE)
========================= */
document.addEventListener("input", e => {

  if (!e.target.dataset.step) return;

  const stepId = Number(e.target.dataset.step);
  const step = steps.find(s => s.id === stepId);
  
  // Handle contact form inputs
  if (step && step.type === "contact-form") {
    const field = e.target.dataset.field;
    const value = e.target.value;
    
    if (!answers[stepId]) answers[stepId] = {};
    answers[stepId][field] = value;
    return;
  }

  // Handle textarea inputs (project details)
  const field = e.target.dataset.field;

  const max = step.screen.fields[field].max;

  let value = e.target.value;

  // 🔒 HARD STOP
  if (value.length > max) {
    value = value.slice(0, max);
    e.target.value = value; // overwrite extra input
  }

  if (!answers[stepId]) answers[stepId] = {};
  answers[stepId][field] = value;

  const exceeded = value.length >= max;

  // Toggle error class
  e.target.classList.toggle("error", exceeded);

  // Toggle error text
  const errorEl = field === "title"
    ? document.querySelector(".title-error")
    : document.querySelector(".desc-error");

  if (errorEl) {
    errorEl.style.display = exceeded ? "block" : "none";
  }
});

  // ===============================
  // LANGUAGE BUTTONS
  // ===============================
  document.addEventListener("click", e => {
    if (!e.target.classList.contains("language-btn")) return;

    const stepId = Number(e.target.dataset.step);
    const key = e.target.dataset.key;
    const type = e.target.dataset.type;
    const value = e.target.dataset.value;

    answers[stepId] = answers[stepId] || {};

    if (type === "single") {
      answers[stepId][key] = value;
    } else {
      const arr = answers[stepId][key] || [];
      answers[stepId][key] = arr.includes(value)
        ? arr.filter(v => v !== value)
        : [...arr, value];
    }

    renderStep();
  });

  // ===============================
  // CHECKBOX CHANGE
  // ===============================
  // document.addEventListener("change", e => {
  //   if (!e.target.dataset.key) return;

  //   const stepId = Number(e.target.dataset.step);
  //   const key = e.target.dataset.key;

  //   if (!answers[stepId]) answers[stepId] = {};
  //   answers[stepId][key] = e.target.checked;
  // });
document.addEventListener("change", function (e) {
  if (!e.target.closest(".confirm-checkbox")) return;

  const submitBtn = document.querySelector(".submit-btn");
  if (!submitBtn) return;

  const allCheckboxes = document.querySelectorAll(
    '.confirm-checkbox input[type="checkbox"]'
  );

  const allChecked = [...allCheckboxes].every(cb => cb.checked);

  submitBtn.disabled = !allChecked;
  submitBtn.classList.toggle("active", allChecked);
  submitBtn.classList.toggle("disabled", !allChecked);
});
// Submit form and redirect
document.addEventListener("click", function (e) {
  const submitBtn = e.target.closest(".submit-btn");
  if (!submitBtn) return;

  // Prevent click if disabled
  if (submitBtn.disabled) return;
  // Prevent default button behavior
  e.preventDefault();

  // OPTIONAL: log final payload
  console.log("FINAL ANSWERS:", answers);
  console.log("STEP 9 DATA:", answers[9]);
  console.log("B2B Stage:", sessionStorage.getItem('b2b_stage'));
  console.log("AJAX URL:", tte_ajax.ajax_url);
  console.log("Nonce:", tte_ajax.nonce);

  // Get B2B stage from sessionStorage
  const b2bStage = sessionStorage.getItem('b2b_stage') || 'launching';
  
  // Prepare form data
  const formData = new FormData();
  formData.append('action', 'eo_submit_form');
  formData.append('nonce', tte_ajax.nonce);
  formData.append('formData', JSON.stringify(answers));
  formData.append('b2bStage', b2bStage);

  console.log("Submitting form data...");

  // Send AJAX request
  fetch(tte_ajax.ajax_url, {
    method: 'POST',
    body: formData,
  })
    .then(response => {
      console.log("Response status:", response.status);
      return response.json();
    })
    .then(data => {
      console.log("Response data:", data);
      if (data.success) {
        console.log('Form submitted successfully:', data.data);
        // Redirect after successful submission
        window.location.href = "http://localhost/electric-octopus-wp/?page_id=86";
      } else {
        console.error('Form submission failed:', data.data);
        alert('Error submitting form: ' + (data.data || 'Unknown error'));
      }
    })
    .catch(error => {
      console.error('Fetch error:', error);
      alert('Error submitting form. Please try again. Details: ' + error.message);
    });
});

  prevBtn.onclick = () => {

    const step = steps[currentStep];

    if ((step.type === "ads-flow" || step.type === "language-flow") && currentSubStep > 0) {
      currentSubStep--;
      renderStep();
      return;
    }
    if (currentStep > 0) {
      currentStep--;
      renderStep();
    }
  };

  nextBtn.onclick = () => {

    const step = steps[currentStep];

    if (step.type === "ads-flow") {

      if (currentSubStep < step.screens.length - 1) {
        currentSubStep++;
        renderStep();
        return;
      } else {
        currentSubStep = 0;
      }
    }
    if (step.type === "language-flow") {
      if (currentSubStep < step.screens.length - 1) {
        currentSubStep++;
        renderStep();
        return;
      } else {
        currentSubStep = 0;
      }
    }

    currentStep++;
    renderStep();
  };

  renderStep();
});