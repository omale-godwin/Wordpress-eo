            { value: "Telecom", icon: "https://cdn.electricoctopus.agency/electric-octopus/industry-logo1.png" },
            { value: "Energy & Utility ", icon: "https://cdn.electricoctopus.agency/electric-octopus/industry-logo2.png" },
            { value: "Logistics", icon: "https://cdn.electricoctopus.agency/electric-octopus/industry-logo3.png" },
