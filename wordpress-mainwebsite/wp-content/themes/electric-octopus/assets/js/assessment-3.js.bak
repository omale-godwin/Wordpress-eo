document.addEventListener("DOMContentLoaded", () => {
// ===============================
  // B2B STAGE IMAGE SWITCH (UPDATED)
  // ===============================

  const stageImageMap = {
    launching: "https://cdn.electricoctopus.agency/electric-octopus/launching.webp",
    growing: "https://cdn.electricoctopus.agency/electric-octopus/growing.webp",
    scaling: "https://cdn.electricoctopus.agency/electric-octopus/scaling.webp"
  };

  const stageCards = document.querySelectorAll(".b2b-stage");
  const stageImage = document.getElementById("b2b-stage-image");

  // 🔹 NEW: set default stage (fallback-safe)
  const savedStage =
    sessionStorage.getItem("b2b_stage") || "launching";

  function setActiveStage(stage) {
    stageCards.forEach(card => {
      const isActive = card.dataset.stage === stage;
      card.classList.toggle("active", isActive);
    });

    if (stageImageMap[stage]) {
      stageImage.src = stageImageMap[stage];
    }

    sessionStorage.setItem("b2b_stage", stage);
  }

  // 🔹 INIT ON LOAD
  setActiveStage(savedStage);

  stageCards.forEach(card => {
    card.addEventListener("click", () => {
      const stage = card.dataset.stage;

      // prevent unnecessary re-render
      if (sessionStorage.getItem("b2b_stage") === stage) return;

      stageImage.style.opacity = 0;
      stageImage.style.transform = "scale(0.96)";

      setTimeout(() => {
        setActiveStage(stage);
        stageImage.style.opacity = 1;
        stageImage.style.transform = "scale(1)";
      }, 200);
    });
  });
// ===============================
  // PART 3 → ASSESSMENT TOGGLE
  // ===============================

  const continueBtn = document.getElementById("part3-continue");
  const part3Section = document.querySelector(".part3-wrapper");
  const assessmentSection = document.getElementById("assessment-form3");

  // Safety check (prevents JS errors)
  if (continueBtn && part3Section && assessmentSection) {
    continueBtn.addEventListener("click", () => {

      // Optional: ensure a stage is selected
      const selectedStage =
        sessionStorage.getItem("b2b_stage") || "launching";

      sessionStorage.setItem("b2b_stage", selectedStage);

      // Toggle visibility
      part3Section.style.display = "none";
      assessmentSection.style.display = "block";

      // Smooth UX
      assessmentSection.scrollIntoView({
        behavior: "smooth",
        block: "start"
      });
    });
  }
  const steps = [
    {
      id: 1,
      type: "ads-flow",
      label: "KEY REQUIREMENTS",
